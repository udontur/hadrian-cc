---
import { OrbDrawer } from "@/components/wrapper/OrbDrawer.tsx"

const { image, title, description, place } = Astro.props

import { getImage } from "astro:assets"
import type { ImageMetadata } from "astro"

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/image/about/*.{webp,png,jpg,jpeg,gif}"
)
const imagePath = "/src/assets/image/about/" + image
if (!images[imagePath]) throw new Error(`"${imagePath} gone bro"`)

const orbImage1 = await getImage({
    src: images[imagePath](),
    format: "webp",
    width: 84,
    height: 84,
})
const orbImage2 = await getImage({
    src: images[imagePath](),
    format: "webp",
    width: 256,
    height: 256,
})
---

<div class={`flex ${place}`}>
    <OrbDrawer
        client:visible
        coverImage={orbImage1}
        contentImage={orbImage2}
        title={title}
        description={description}
    />
</div>
