---
import { Image } from "astro:assets";
import udonturImage from "@assets/images/udontur1000-transparent.png";
---
<div class="flex flex-col">
    <div class="h-48"></div>
    <div class="flex justify-between items-center">
        <div class="">
            <div>
                Hello!!!
            </div>
            <div class="font-big text-8xl">Hadrian</div>
            <div>is my name</div>
        </div>
        <div class="w-96">
            <div class="hero-image-parallax" data-parallax>
                <div class="hero-image-shadow" aria-hidden="true"></div>
                <div class="hero-image-frame">
                    <div class="hero-image-glow" aria-hidden="true"></div>
                    <div class="hero-image-gloss" aria-hidden="true"></div>
                    <Image
                        class="hero-image"
                        src={udonturImage}
                        alt="My profile picture (it's a cartoon turtle!)"
                    />
                </div>
            </div>
        </div>
    </div>
    <div class="h-48"></div>
</div>

<style>
    .hero-image-parallax {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1;
        perspective: 1400px;
        --parallax-x: 50%;
        --parallax-y: 50%;
        --tilt-x: 0deg;
        --tilt-y: 0deg;
        --shadow-x: 0px;
        --shadow-y: 18px;
    }

    .hero-image-shadow {
        position: absolute;
        inset: 12% 14% 2% 14%;
        background: radial-gradient(
            circle at center,
            color-mix(in srgb, var(--color-main) 38%, transparent) 0%,
            transparent 68%
        );
        filter: blur(30px);
        transform: translate3d(var(--shadow-x), var(--shadow-y), 0) scale(1.06);
        opacity: 0.8;
        pointer-events: none;
    }

    .hero-image-frame {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 2rem;
        transform-style: preserve-3d;
        transform: rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
        transition: transform 110ms ease-out;
        overflow: hidden;
        background: radial-gradient(
            circle at var(--parallax-x) var(--parallax-y),
            color-mix(in srgb, var(--color-main) 12%, transparent) 0%,
            transparent 52%
        );
    }

    .hero-image {
        position: relative;
        width: 100%;
        height: 100%;
        object-fit: contain;
        transform: translateZ(22px);
        filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.45));
        user-select: none;
        -webkit-user-drag: none;
    }

    .hero-image-glow,
    .hero-image-gloss {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        pointer-events: none;
    }

    .hero-image-glow {
        transform: translateZ(8px);
        background:
            radial-gradient(
                48% 42% at var(--parallax-x) var(--parallax-y),
                color-mix(in srgb, var(--color-main) 44%, transparent),
                transparent 74%
            ),
            conic-gradient(
                from 210deg at var(--parallax-x) var(--parallax-y),
                color-mix(in srgb, var(--color-main) 30%, transparent),
                transparent 35%,
                color-mix(in srgb, var(--color-main) 20%, transparent) 62%,
                transparent 85%
            );
        mix-blend-mode: screen;
        opacity: 0.95;
    }

    .hero-image-gloss {
        transform: translateZ(14px);
        background: linear-gradient(
            140deg,
            rgba(255, 255, 255, 0.34) 0%,
            rgba(255, 255, 255, 0.1) 18%,
            transparent 44%
        );
        opacity: 0.7;
    }
</style>

<script>
    const cards = document.querySelectorAll<HTMLElement>("[data-parallax]");

    cards.forEach((card) => {
        const maxTilt = 14;
        const influence = 0.35;

        const updateCard = (event: MouseEvent) => {
            const rect = card.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;

            const dx = Math.max(
                -1,
                Math.min(1, (event.clientX - centerX) / (window.innerWidth * influence))
            );
            const dy = Math.max(
                -1,
                Math.min(1, (event.clientY - centerY) / (window.innerHeight * influence))
            );

            const px = (dx + 1) / 2;
            const py = (dy + 1) / 2;

            const rotateY = (px - 0.5) * maxTilt * 2;
            const rotateX = (0.5 - py) * maxTilt * 2;

            card.style.setProperty("--parallax-x", `${(px * 100).toFixed(2)}%`);
            card.style.setProperty("--parallax-y", `${(py * 100).toFixed(2)}%`);
            card.style.setProperty("--tilt-x", `${rotateX.toFixed(2)}deg`);
            card.style.setProperty("--tilt-y", `${rotateY.toFixed(2)}deg`);
            card.style.setProperty("--shadow-x", `${((px - 0.5) * 14).toFixed(2)}px`);
            card.style.setProperty("--shadow-y", `${(16 + py * 10).toFixed(2)}px`);
        };

        const resetCard = () => {
            card.style.setProperty("--parallax-x", "50%");
            card.style.setProperty("--parallax-y", "50%");
            card.style.setProperty("--tilt-x", "0deg");
            card.style.setProperty("--tilt-y", "0deg");
            card.style.setProperty("--shadow-x", "0px");
            card.style.setProperty("--shadow-y", "18px");
        };

        window.addEventListener("mousemove", updateCard);
        window.addEventListener("mouseleave", resetCard);
    });
</script>