---
const { name, url, svg } = Astro.props

import { getImage } from "astro:assets"
import type { ImageMetadata } from "astro"

const svgs = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/icons/*.svg"
)
const svgPath = "/src/assets/icons/" + svg
if (!svgs[svgPath]) throw new Error(`"${svgPath} gone bro"`)

const svgOpt = await getImage({
    src: svgs[svgPath](),
    format: "svg",
    width: 48,
    height: 48,
})
---

<a class="no-underline text-white fill-white" href={url}>
    <button
        class="
        text-2xl flex items-center justify-center flex-row p-3
        border border-solid rounded-[16px] border-border
        ease-in-out duration-200
        bg-card cursor-pointer no-underline gap-4
        hover:bg-secondary hover:border-primary
    "
    >
        <div class="invert-100 brightness-0">
            <img src={svgOpt.src} alt={name} width="48" height="48" />
        </div>
    </button>
</a>
