---
import { Image } from "astro:assets"
import udontur from "@/assets/image/udontur1000-transparent-blur.png"
import {
    Name,
    UserNameFlash,
} from "@/components/wrapper/HeroText.tsx"
import Linktree from "./Linktree.astro"
---

<div class="flex flex-col gap-96">
    <div class="flex max-w-md min-w-0 flex-col">
        <div class="-translate-x-2 -mb-8">
            <Name
                client:load
                speed={0.25}
                className="text-[8rem] font-bold text-primary font-heading"
                text="Hadrian"
            />
        </div>
        <div class="flex flex-col gap-1">
            <div class="mb-2 flex">
                <Name
                    client:load
                    speed={0.25}
                    className="text-5xl font-bold"
                    text="Lau "
                />
                <Name
                    client:load
                    speed={0.25}
                    className="text-5xl"
                    text="劉曜熙"
                />
            </div>
            <div>
                <UserNameFlash
                    client:load
                    speed={42}
                    className="text-[54px] text-muted-foreground"
                    text="@udontur"
                />
            </div>
        </div>
    </div>
    <!-- This blur thingy took so long to fix!!!  -->
    <div class="flex flex-col items-center gap-0">
        <Image src={udontur} alt="avatar" width="512" />
        <Linktree />
    </div>
</div>
